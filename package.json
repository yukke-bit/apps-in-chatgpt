{
  "name": "apps-in-chatgpt",
  "private": true,
  "version": "0.1.0",
  "description": "Local workspace for running the Pizzaz Apps SDK Node example.",
  "type": "module",
  "scripts": {
    "build": "tsx ./build-all.mts",
    "build:pizzaz": "tsx ./build-all.mts --target pizzaz",
    "serve": "serve \"%CD%\\assets\" -p 4444 --cors",
    "start:pizzaz": "corepack pnpm --filter pizzaz-mcp-node start",
    "dev:pizzaz": "corepack pnpm run build && corepack pnpm run start:pizzaz",
    "tsc": "tsc -b",
    "check": "tsc -b"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.3.0",
    "@vitejs/plugin-react": "^4.5.2",
    "fast-glob": "^3.3.3",
    "serve": "^14.2.4",
    "tailwindcss": "4.1.11",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.1"
  },
  "dependencies": {
    "@openai/apps-sdk-ui": "^0.2.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.0.0",
    "embla-carousel-react": "^8.0.0",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.536.0",
    "mapbox-gl": "^3.14.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  }
}
